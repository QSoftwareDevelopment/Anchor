# Copy to .env.local and fill in. Also add all of these to Vercel project settings.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=

# Google OAuth (reuse or clone TextBot's OAuth client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.qsoftware.ca/api/gcal/callback

# Vercel cron protection (any long random string)
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=https://app.qsoftware.ca

# Twilio (optional — morning brief SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Founder accounts — used once by `npm run seed` to create exactly the two
# logins (Sid + Aaryan) and nothing else. Safe to delete after seeding.
FOUNDER_SID_EMAIL=siddharth.phatak42@gmail.com
FOUNDER_SID_PASSWORD=
FOUNDER_AARYAN_EMAIL=
FOUNDER_AARYAN_PASSWORD=
